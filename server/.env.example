# LocalAid Connect — server environment
# Copy this file to `.env` and adjust as needed. `.env` is gitignored.

# ── HTTP ──────────────────────────────────────────────────────
# Port the Express server listens on.
PORT=3001

# ── Database ──────────────────────────────────────────────────
# Path to the SQLite database file. Default is relative to server/.
# The server creates this file (and the schema) on first boot if missing.
DB_PATH=./db/localaid.sqlite

# ── AI parsing (REQ-3.1) ──────────────────────────────────────
# Optional. When unset, /api/ai/parse falls back to local keyword extraction
# and responds with { source: "keyword" }. Set this to enable real LLM parsing
# and responses will come back with { source: "ai" }.
OPENAI_API_KEY=

# OpenAI model to use for parsing. gpt-4o-mini is cheap and fast for this use.
OPENAI_MODEL=gpt-4o-mini

# ── Admin auth (placeholder — NOT enforced yet) ───────────────
# Reserved for future admin-route protection (REQ-3.5 + TODO in index.js).
# When auth is added, the admin endpoints will expect this token in a header
# like `Authorization: Bearer <ADMIN_TOKEN>`. Leaving it blank for now.
ADMIN_TOKEN=
